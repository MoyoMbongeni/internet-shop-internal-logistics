# Kropp | Sheet API — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Your Google Spreadsheet ID (from the sheet URL)
SPREADSHEET_ID=your_spreadsheet_id_here

# The exact tab name in your sheet
SHEET_TAB_NAME=Kargo Takip

# A secret string you invent — paste the same value into the app's .env
API_SECRET=make_up_a_strong_random_string_here
